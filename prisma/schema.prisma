generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Supermarket {
  id            String         @id @default(uuid())
  name          String
  address       String?
  phone         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  customers     Customer[]
  expenses      Expense[]
  expiredStocks ExpiredStock[]
  notifications Notification[]
  payments      Payment[]
  products      Product[]
  purchases     Purchase[]
  sales         Sale[]
  suppliers     Supplier[]
  users         User[]
}

model User {
  id            String      @id @default(uuid())
  supermarketId String
  username      String
  password      String
  role          String
  name          String
  pin           String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  expenses      Expense[]
  sales         Sale[]
  supermarket   Supermarket @relation(fields: [supermarketId], references: [id])

  @@unique([supermarketId, username])
}

model Product {
  id            String         @id @default(uuid())
  supermarketId String
  name          String
  barcode       String
  category      String
  brand         String?
  unit          String
  costPrice     Decimal
  sellingPrice  Decimal
  taxPercent    Decimal
  minStockLevel Int            @default(10)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  pricingType   String?        @default("MRP")
  expiredStocks ExpiredStock[] @relation("ProductToExpired")
  supermarket   Supermarket    @relation(fields: [supermarketId], references: [id])
  batches       ProductBatch[]
  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]

  @@unique([supermarketId, barcode])
}

model ProductBatch {
  id           String    @id @default(uuid())
  productId    String
  batchNumber  String
  expiryDate   DateTime?
  quantity     Float
  purchaseId   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  costPrice    Decimal?
  sellingPrice Decimal?
  product      Product   @relation(fields: [productId], references: [id])
  purchase     Purchase? @relation(fields: [purchaseId], references: [id])
}

model Supplier {
  id            String      @id @default(uuid())
  supermarketId String
  name          String
  phone         String?
  address       String?
  gstNumber     String?
  isActive      Boolean     @default(true)
  purchases     Purchase[]
  supermarket   Supermarket @relation(fields: [supermarketId], references: [id])
}

model Purchase {
  id            String         @id @default(uuid())
  supermarketId String
  supplierId    String
  invoiceNumber String?
  totalAmount   Decimal
  status        String         @default("PENDING")
  date          DateTime       @default(now())
  paidAmount    Decimal?       @default(0)
  paymentMode   String?        @default("CASH")
  batches       ProductBatch[]
  supermarket   Supermarket    @relation(fields: [supermarketId], references: [id])
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  items         PurchaseItem[]
}

model PurchaseItem {
  id           String    @id @default(uuid())
  purchaseId   String
  productId    String
  quantity     Float
  costPrice    Decimal
  taxAmount    Decimal?
  total        Decimal
  expiryDate   DateTime? @db.Timestamptz(6)
  sellingPrice Decimal?
  product      Product   @relation(fields: [productId], references: [id])
  purchase     Purchase  @relation(fields: [purchaseId], references: [id])
}

model Sale {
  id                  String      @id @default(uuid())
  supermarketId       String
  invoiceNumber       String
  cashierId           String
  date                DateTime    @default(now())
  subTotal            Decimal
  taxTotal            Decimal
  discount            Decimal     @default(0)
  totalAmount         Decimal
  paymentMode         String
  customerId          String?
  originalPaymentMode String?
  cashier             User        @relation(fields: [cashierId], references: [id])
  customer            Customer?   @relation(fields: [customerId], references: [id])
  supermarket         Supermarket @relation(fields: [supermarketId], references: [id])
  items               SaleItem[]
}

model Notification {
  id            String      @id @default(uuid())
  supermarketId String
  title         String
  message       String
  type          String
  link          String?
  isRead        Boolean     @default(false)
  createdAt     DateTime    @default(now())
  supermarket   Supermarket @relation(fields: [supermarketId], references: [id])
}

model SaleItem {
  id        String  @id @default(uuid())
  saleId    String
  productId String
  quantity  Float
  unitPrice Decimal
  taxAmount Decimal
  total     Decimal
  product   Product @relation(fields: [productId], references: [id])
  sale      Sale    @relation(fields: [saleId], references: [id])
}

model Customer {
  id            String      @id @default(uuid())
  supermarketId String
  name          String?
  phone         String?
  flatNumber    String?
  supermarket   Supermarket @relation(fields: [supermarketId], references: [id])
  payments      Payment[]
  sales         Sale[]

  @@unique([supermarketId, phone])
}

model Payment {
  id            String      @id @default(uuid())
  supermarketId String
  customerId    String
  amount        Decimal
  date          DateTime    @default(now())
  note          String?
  type          String      @default("CREDIT_PAYMENT")
  paymentMode   String      @default("CASH")
  customer      Customer    @relation(fields: [customerId], references: [id])
  supermarket   Supermarket @relation(fields: [supermarketId], references: [id])
}

model Expense {
  id            String      @id @default(uuid())
  supermarketId String
  title         String
  amount        Decimal
  category      String
  date          DateTime    @default(now())
  note          String?
  userId        String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  supermarket   Supermarket @relation(fields: [supermarketId], references: [id])
  user          User?       @relation(fields: [userId], references: [id])
}

model ExpiredStock {
  id            String      @id @default(uuid())
  supermarketId String
  productId     String
  batchId       String
  quantity      Float
  type          String
  status        String      @default("PENDING")
  newBatchId    String?
  note          String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  product       Product     @relation("ProductToExpired", fields: [productId], references: [id])
  supermarket   Supermarket @relation(fields: [supermarketId], references: [id])
}
